apiVersion: v1
kind: LimitRange
metadata:
  name: {{ namespace_name }}-limits
  namespace: {{ namespace_name }}
spec:
  limits:
    - type: Container
      default:
        cpu: "{{ limitrange.default_cpu }}"
        memory: "{{ limitrange.default_memory }}"
      defaultRequest:
        cpu: "{{ limitrange.default_request_cpu }}"
        memory: "{{ limitrange.default_request_memory }}"
