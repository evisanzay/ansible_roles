apiVersion: policy.open-cluster-management.io/v1
kind: Policy
metadata:
  name: {{ acm_policy_name }}
  namespace: {{ acm_policy_namespace }}
spec:
  remediationAction: {{ acm_policy_remediation_action }}
  disabled: false
  policy-templates:
    - objectDefinition:
        apiVersion: policy.open-cluster-management.io/v1
        kind: ConfigurationPolicy
        metadata:
          name: {{ acm_configurationpolicy_name }}
        spec:
          remediationAction: {{ acm_policy_remediation_action }}
          severity: {{ acm_configurationpolicy_severity }}
          object-templates:
{% for definition in acm_configurationpolicy_object_definitions %}
            - complianceType: {{ definition.complianceType | default('musthave') }}
              objectDefinition:
{{ definition.objectDefinition | to_nice_yaml(indent=16) | indent(16, true) }}
{% endfor %}
