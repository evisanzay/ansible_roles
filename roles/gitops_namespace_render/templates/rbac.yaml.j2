apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ namespace_name }}-admin-group
  namespace: {{ namespace_name }}
subjects:
  - kind: Group
    name: {{ admin_group }}
    apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: admin
  apiGroup: rbac.authorization.k8s.io
---
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  name: {{ namespace_name }}-reader-group
  namespace: {{ namespace_name }}
subjects:
  - kind: Group
    name: {{ reader_group }}
    apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: view
  apiGroup: rbac.authorization.k8s.io
